```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
*.egg-info/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# OS files
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.mypy_cache/
```