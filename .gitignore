```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
*.pyc
*.pyo
*.pyd

# OS generated files
.DS_Store
Thumbs.db
```